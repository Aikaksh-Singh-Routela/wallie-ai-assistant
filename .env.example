# ============ LLM Providers ============
# At least one must be set. Select active one via "llm.provider" in config.yaml.
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ============ TTS Providers ============
# Key is only required for the provider selected in config.yaml.
FISH_API_KEY=
ELEVENLABS_API_KEY=

# ============ Stream Platforms ============
# YouTube: Google OAuth (place client_secret.json under scripts/)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_SECRET_FILE=scripts/client_secret.json
YOUTUBE_LIVE_CHAT_ID=

# Twitch: oauth token from https://twitchtokengenerator.com
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNEL=
TWITCH_NICK=

# Kick: channel slug (public chat, no auth needed)
KICK_CHANNEL=

# ============ Dashboard ============
LOG_LEVEL=INFO
# Host: 127.0.0.1 for local only (no PIN needed), 0.0.0.0 to access from phone/tablet
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
# PIN: set a 4+ digit PIN for dashboard access. If empty and host is 0.0.0.0,
# a random PIN is auto-generated each startup and shown in the terminal.
DASHBOARD_PIN=
